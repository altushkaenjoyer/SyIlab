generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ──────────────────────────────────────────────────────────────────

enum Role {
  STUDENT
  INSTRUCTOR
  PROCTOR
  ADMIN
}

enum Language {
  python
  javascript
  typescript
}

enum SessionStatus {
  SCHEDULED
  OPEN
  CLOSED
}

enum FlagLevel {
  NORMAL
  MONITOR
  REVIEW
  INTERVIEW
}

enum QueueStatus {
  PENDING
  REVIEWED
  CLEARED
  CONFIRMED
}

// ── MODELS ─────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String
  fullName          String
  role              Role      @default(STUDENT)
  emailVerified     Boolean   @default(false)
  verificationToken String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  enrollments        Enrollment[]
  baselines          BaselineSession[]
  submissions        Submission[]
  taughtCourses      Course[]          @relation("InstructorCourses")
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Institution {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  courses Course[]

  @@map("institutions")
}

model Cohort {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  courses Course[]
  stats   CohortStats[]

  @@map("cohorts")
}

model Course {
  id             String   @id @default(cuid())
  name           String
  institutionId  String
  instructorId   String
  cohortId       String
  alertThreshold Float    @default(2.5)
  // Max genealogy violations for this course (used in scoring normalization)
  maxViolations  Int      @default(8)
  createdAt      DateTime @default(now())

  institution Institution      @relation(fields: [institutionId], references: [id])
  instructor  User             @relation("InstructorCourses", fields: [instructorId], references: [id])
  cohort      Cohort           @relation(fields: [cohortId], references: [id])
  enrollments Enrollment[]
  sessions    ProctoredSession[]
  submissions Submission[]
  baselines   BaselineSession[]

  @@index([instructorId])
  @@index([cohortId])
  @@map("courses")
}

model Enrollment {
  studentId  String
  courseId   String
  enrolledAt DateTime @default(now())

  student User   @relation(fields: [studentId], references: [id])
  course  Course @relation(fields: [courseId], references: [id])

  @@id([studentId, courseId])
  @@map("enrollments")
}

model ProctoredSession {
  id                       String        @id @default(cuid())
  courseId                 String
  status                   SessionStatus @default(SCHEDULED)
  scheduledAt              DateTime
  durationMinutes          Int
  roomLabel                String?
  openedAt                 DateTime?
  closedAt                 DateTime?
  networkIsolationConfirmed Boolean      @default(false)
  createdAt                DateTime      @default(now())

  course    Course            @relation(fields: [courseId], references: [id])
  baselines BaselineSession[]

  @@index([courseId, status])
  @@map("proctored_sessions")
}

model BaselineSession {
  id            String    @id @default(cuid())
  studentId     String
  sessionId     String
  courseId      String
  codeEncrypted String    // AES-256 encrypted at application layer
  contentHash   String    // SHA-256 of plaintext code
  language      Language
  lockedAt      DateTime? // NULL = not yet locked; set once = immutable
  createdAt     DateTime  @default(now())

  student  User             @relation(fields: [studentId], references: [id])
  session  ProctoredSession @relation(fields: [sessionId], references: [id])
  course   Course           @relation(fields: [courseId], references: [id])
  features BaselineFeatures?

  @@unique([studentId, courseId])
  @@index([studentId, courseId])
  @@map("baseline_sessions")
}

model BaselineFeatures {
  id         String @id @default(cuid())
  baselineId String @unique

  // Sophistication score
  totalScore Float

  // Structural metrics (used in C2 — FIX 2: std devs stored per student)
  errorHandlingTier Int
  architectureTier  Int
  typeSafetyScore   Int
  controlFlowPref   Int @default(0) // 0=imperative,1=mixed,2=functional

  // Boolean presence features
  hasDecorators        Boolean @default(false)
  hasAsync             Boolean @default(false)
  hasContextManagers   Boolean @default(false)
  hasMetaclasses       Boolean @default(false)
  hasDependencyInjection Boolean @default(false)
  hasAbstractClasses   Boolean @default(false)
  hasDataclasses       Boolean @default(false)

  // Lexical metrics (used in C1)
  namingVerbosity Float
  commentDensity  Float

  // Complexity metrics
  cyclomaticAvg   Float
  maxNestingDepth Int

  baseline BaselineSession @relation(fields: [baselineId], references: [id])

  @@map("baseline_features")
}

model Submission {
  id            String    @id @default(cuid())
  studentId     String
  courseId      String
  weekNumber    Int
  language      Language
  ensembleScore Float?
  flagLevel     FlagLevel @default(NORMAL)
  submittedAt   DateTime  @default(now())

  student    User                @relation(fields: [studentId], references: [id])
  course     Course              @relation(fields: [courseId], references: [id])
  features   SubmissionFeatures?
  violations GenealogyViolation[]
  queueItem  InstructorQueue?

  @@index([studentId, courseId, weekNumber])
  @@index([courseId, weekNumber, flagLevel])
  @@index([ensembleScore])
  @@map("submissions")
}

model SubmissionFeatures {
  id           String @id @default(cuid())
  submissionId String @unique

  // Same fields as BaselineFeatures
  totalScore    Float
  errorHandlingTier Int
  architectureTier  Int
  typeSafetyScore   Int
  controlFlowPref   Int @default(0)

  hasDecorators          Boolean
  hasAsync               Boolean
  hasContextManagers     Boolean
  hasMetaclasses         Boolean
  hasDependencyInjection Boolean
  hasAbstractClasses     Boolean
  hasDataclasses         Boolean

  namingVerbosity Float
  commentDensity  Float
  cyclomaticAvg   Float
  maxNestingDepth Int

  // Trajectory analysis fields (from final formula)
  expectedScore      Float   // base × 1.15^(week-1)
  jumpRatio          Float   // actual / expected
  trajectoryZ        Float   // (actual - cohortMean) / cohortStd
  cohortPercentile   Float
  weeksCompressed    Float   // (current - baseline) / expected_weekly_increment
  regressionRatio    Float   @default(1.0) // current / prev (for C6)

  // C1 deviation z-scores (student-specific, FIX 2)
  zCommentDensity  Float @default(0)
  zNamingVerbosity Float @default(0)

  // All techniques detected in this submission (for genealogy history tracking)
  detectedTechniques String[] @default([])

  submission Submission @relation(fields: [submissionId], references: [id])

  @@map("submission_features")
}

model GenealogyViolation {
  id                String @id @default(cuid())
  submissionId      String
  technique         String
  missingPrerequisite String
  severityWeight    Float

  submission Submission @relation(fields: [submissionId], references: [id])

  @@index([submissionId])
  @@map("genealogy_violations")
}

model CohortStats {
  id              String   @id @default(cuid())
  cohortId        String
  weekNumber      Int
  meanScore       Float
  stdDev          Float
  p10             Float
  p50             Float
  p90             Float
  p90Threshold    Float
  submissionCount Int
  updatedAt       DateTime @updatedAt

  cohort Cohort @relation(fields: [cohortId], references: [id])

  @@unique([cohortId, weekNumber])
  @@index([cohortId, weekNumber])
  @@map("cohort_stats")
}

model InstructorQueue {
  id             String      @id @default(cuid())
  submissionId   String      @unique
  priorityScore  Float
  status         QueueStatus @default(PENDING)
  llmGuidance    String?
  instructorNote String?
  resolvedAt     DateTime?
  createdAt      DateTime    @default(now())

  submission Submission @relation(fields: [submissionId], references: [id])

  @@index([status, priorityScore])
  @@map("instructor_queue")
}

model TechniquePrerequisite {
  technique      String   @id
  requires       String[] // Array of technique names
  severityWeight Float    @default(0.5)

  @@map("technique_prerequisites")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
