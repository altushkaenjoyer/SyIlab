    {
      "name": "02 · Auth — Email верификация",
      "item": [
        {
          "name": "🔧 DEV: Получить токен из БД (без email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const d = pm.response.json();",
                  "  if (d.verification_token) {",
                  "    pm.collectionVariables.set('verification_token', d.verification_token);",
                  "    console.log('✅ verification_token сохранён автоматически!');",
                  "    console.log('Сразу запускай «Верификация email» — токен уже вставлен');",
                  "  } else {",
                  "    console.log('Email уже верифицирован или токен не найден');",
                  "    console.log('email_verified: ' + d.email_verified);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/dev/token?email={{student_email}}",
              "query": [{ "key": "email", "value": "{{student_email}}" }]
            }
          }
        },
        {
          "name": "✅ Верификация email",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.collectionVariables.get('verification_token');",
                  "if (!token || token === 'ВСТАВЬ_ТОКЕН_ИЗ_ПИСЬМА') {",
                  "  console.warn('⚠️  Вставь токен из письма в переменную verification_token!');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.collectionVariables.set('verification_token', '');",
                  "  console.log('✅ Email верифицирован! Теперь запускай «Логин»');",
                  "} else {",
                  "  console.log('❌ Ошибка: ' + pm.response.json().message);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/verify-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verification_token}}\"\n}"
            }
          }
        },
        {
          "name": "🔧 DEV: Получить токен инструктора из БД",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const d = pm.response.json();",
                  "  if (d.verification_token) {",
                  "    pm.collectionVariables.set('verification_token', d.verification_token);",
                  "    console.log('✅ verification_token сохранён! Запускай «Верификация email»');",
                  "  } else {",
                  "    console.log('Email уже верифицирован: ' + d.email_verified);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/auth/dev/token?email={{instructor_email}}",
              "query": [{ "key": "email", "value": "{{instructor_email}}" }]
