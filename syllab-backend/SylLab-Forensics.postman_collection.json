        {
          "name": "GET /submissions — инструктор фильтрует по флагу",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/submissions?course_id={{course_id}}&flag_level=INTERVIEW&sort=-ensemble_score",
              "query": [
                { "key": "course_id",  "value": "{{course_id}}" },
                { "key": "flag_level", "value": "INTERVIEW" },
                { "key": "sort",       "value": "-ensemble_score" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{instructor_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const data = pm.response.json().data;",
                  "pm.test('Все записи INTERVIEW', () => {",
                  "  data.forEach(s => pm.expect(s.flag_level).to.eql('INTERVIEW'));",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "05 · Instructor Queue",
      "item": [
        {
          "name": "GET /instructor/queue — очередь на проверку",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/instructor/queue?status=PENDING",
              "query": [{ "key": "status", "value": "PENDING" }]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{instructor_token}}" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Есть массив', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "06 · Edge Cases",
      "item": [
        {
          "name": "GET /nonexistent — 404 обработчик",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/nonexistent-route"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('404 NOT_FOUND', () => pm.response.to.have.status(404));",
                  "pm.test('Код NOT_FOUND', () => pm.expect(pm.response.json().error).to.eql('NOT_FOUND'));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET /auth/me — 401 невалидный токен",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer eyJhbGciOiJIUzI1NiJ9.fake.signature" }]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('401 UNAUTHORIZED', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    }
