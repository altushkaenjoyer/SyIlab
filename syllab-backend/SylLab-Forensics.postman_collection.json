  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "student_token", "value": "", "type": "string" },
    { "key": "instructor_token", "value": "", "type": "string" },
    { "key": "refresh_token", "value": "", "type": "string" },
    { "key": "verification_token", "value": "ВСТАВЬ_ТОКЕН_ИЗ_ПИСЬМА", "type": "string" },
    { "key": "reset_token", "value": "ВСТАВЬ_ТОКЕН_ИЗ_ПИСЬМА", "type": "string" },
    { "key": "session_id", "value": "", "type": "string" },
    { "key": "submission_id", "value": "", "type": "string" },
    { "key": "queue_item_id", "value": "", "type": "string" },
    { "key": "course_id", "value": "demo-course-cs101", "type": "string" },
    { "key": "student_email", "value": "student@test.com", "type": "string" },
    { "key": "instructor_email", "value": "instructor@test.com", "type": "string" }
