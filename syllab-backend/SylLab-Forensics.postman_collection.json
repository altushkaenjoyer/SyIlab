                ]
              }
            }
          ]
        },
        {
          "name": "POST /submissions/analyze — 🚨 INTERVIEW (enterprise-код от новичка)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/submissions/analyze",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": \"{{course_id}}\",\n  \"week_number\": 4,\n  \"language\": \"python\",\n  \"code\": \"from abc import ABC, abstractmethod\\nfrom typing import Optional, List, Dict\\nfrom dataclasses import dataclass\\n\\n@dataclass\\nclass StudentRecord:\\n    id: int\\n    name: str\\n    grade: float\\n\\nclass BaseRepository(ABC):\\n    @abstractmethod\\n    async def find_by_id(self, id: int) -> Optional[StudentRecord]:\\n        pass\\n\\nclass StudentRepository(BaseRepository):\\n    def __init__(self, db_connection: object):\\n        self._db = db_connection\\n        self._cache: Dict[int, StudentRecord] = {}\\n\\n    async def find_by_id(self, id: int) -> Optional[StudentRecord]:\\n        if id in self._cache:\\n            return self._cache[id]\\n        try:\\n            result = await self._db.query(f\\\"SELECT * FROM students WHERE id = {id}\\\")\\n            return StudentRecord(**result)\\n        except Exception as e:\\n            raise RuntimeError(f\\\"Database error: {e}\\\") from e\\n\\nclass GradeService:\\n    def __init__(self, repo: BaseRepository):\\n        self._repo = repo\\n\\n    async def get_top_students(self, threshold: float) -> List[StudentRecord]:\\n        students = await self._repo.find_all()\\n        return [s for s in students if s.grade >= threshold]\\n\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('submission_id', d.submission_id || '');",
                  "pm.test('🚨 flag_level = INTERVIEW', () => pm.expect(d.flag_level).to.eql('INTERVIEW'));",
                  "pm.test('ensemble_score высокий (≥0.80)', () => pm.expect(d.ensemble_score).to.be.at.least(0.80));",
                  "pm.test('needs_interview = true', () => pm.expect(d.needs_interview).to.be.true);",
                  "pm.test('jump_ratio огромный', () => pm.expect(d.jump_ratio).to.be.above(5));",
                  "pm.test('Есть genealogy_violations', () => pm.expect(d.genealogy_violations.length).to.be.above(0));",
                  "pm.test('Есть score_breakdown', () => pm.expect(d).to.have.property('score_breakdown'));"
                ]
              }
            }
          ]
        },
