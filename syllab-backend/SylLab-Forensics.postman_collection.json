                  "  console.log('Flag: ' + d.flag_level + ' | Score: ' + (d.ensemble_score * 100).toFixed(1) + '%');",
                  "  if (d.flag_level === 'REVIEW' || d.flag_level === 'INTERVIEW') {",
                  "    console.log('📧 Инструктор получит email-уведомление!');",
                  "  }",
                  "}"
                ]
              }
