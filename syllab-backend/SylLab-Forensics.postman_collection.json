      "name": "04 · Submissions (анализ кода)",
      "item": [
        {
          "name": "POST /submissions/analyze — 422 неподдерживаемый язык",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/submissions/analyze",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" },
              { "key": "Content-Type",   "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": \"{{course_id}}\",\n  \"week_number\": 4,\n  \"language\": \"ruby\",\n  \"code\": \"puts 'hello world'\"\n}"
            }
          },
          "event": [
