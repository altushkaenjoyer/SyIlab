                  "  console.log('=== СЛЕДУЮЩИЙ ШАГ ===');",
                  "  console.log('1. Открой почту ' + JSON.parse(pm.request.body.raw).email);",
                  "  console.log('2. Найди письмо от SylLab-Forensics');",
                  "  console.log('3. Скопируй токен из ссылки: ...?token=ВОТ_ЭТО');",
                  "  console.log('4. Вставь в переменную коллекции: verification_token');",
                  "  console.log('5. Запусти запрос «Верификация email»');",
