          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/submissions/analyze",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": \"{{course_id}}\",\n  \"week_number\": 3,\n  \"language\": \"python\",\n  \"code\": \"from abc import ABC, abstractmethod\\nfrom typing import Generic, TypeVar, Optional, Protocol\\nfrom dataclasses import dataclass, field\\nfrom contextlib import contextmanager\\nimport asyncio\\nimport logging\\n\\nT = TypeVar('T')\\nlogger = logging.getLogger(__name__)\\n\\n\\nclass Repository(Protocol[T]):\\n    def find_by_id(self, id: int) -> Optional[T]: ...\\n    def save(self, entity: T) -> T: ...\\n\\n\\n@dataclass\\nclass UserEntity:\\n    id: int\\n    name: str\\n    permissions: list[str] = field(default_factory=list)\\n\\n\\nclass AbstractService(ABC, Generic[T]):\\n    def __init__(self, repo: Repository[T]) -> None:\\n        self._repo = repo\\n        self._cache: dict[int, T] = {}\\n\\n    @abstractmethod\\n    def validate(self, entity: T) -> bool: ...\\n\\n    @contextmanager\\n    def transaction(self):\\n        logger.info('Starting transaction')\\n        try:\\n            yield self\\n            logger.info('Transaction committed')\\n        except Exception as exc:\\n            logger.error('Transaction rolled back: %s', exc)\\n            raise\\n\\n    async def fetch_async(self, id: int) -> Optional[T]:\\n        if id in self._cache:\\n            return self._cache[id]\\n        loop = asyncio.get_event_loop()\\n        result = await loop.run_in_executor(None, self._repo.find_by_id, id)\\n        if result:\\n            self._cache[id] = result\\n        return result\\n\"\n}"
            }
          }
        },
        {
          "name": "Получить сабмишн по ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }],
            "url": "{{base_url}}/submissions/{{submission_id}}"
          }
        },
        {
          "name": "Список (студент — только свои)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }],
            "url": {
              "raw": "{{base_url}}/submissions?limit=10",
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        },
        {
          "name": "Список (инструктор — фильтр по INTERVIEW)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{instructor_token}}" }],
            "url": {
              "raw": "{{base_url}}/submissions?flag_level=INTERVIEW&course_id={{course_id}}",
              "query": [
                { "key": "flag_level", "value": "INTERVIEW" },
                { "key": "course_id", "value": "{{course_id}}" }
              ]
            }
          }
        },
        {
          "name": "❌ 422 — неподдерживаемый язык",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{student_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/submissions/analyze",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_id\": \"{{course_id}}\",\n  \"week_number\": 2,\n  \"language\": \"java\",\n  \"code\": \"System.out.println('hello');\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "08 · Instructor Queue",
      "item": [
        {
          "name": "Очередь PENDING ✦ сохраняет queue_item_id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const items = pm.response.json().data;",
                  "  if (items && items.length > 0) {",
                  "    pm.collectionVariables.set('queue_item_id', items[0].id);",
                  "    console.log('✅ queue_item_id сохранён: ' + items[0].id);",
                  "    console.log('Флаг: ' + items[0].submission.flagLevel + ' | Score: ' + (items[0].priority_score * 100).toFixed(1) + '%');",
                  "  } else {",
                  "    console.log('Очередь пуста — сначала запусти INTERVIEW-анализ');",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{instructor_token}}" }],
            "url": {
              "raw": "{{base_url}}/instructor/queue?status=PENDING",
              "query": [{ "key": "status", "value": "PENDING" }]
            }
          }
        },
        {
          "name": "Детали queue item",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{instructor_token}}" }],
            "url": "{{base_url}}/instructor/queue/{{queue_item_id}}"
          }
        },
        {
          "name": "Разрешить — CLEARED (студент честный)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{instructor_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/instructor/queue/{{queue_item_id}}/resolve",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CLEARED\",\n  \"instructor_note\": \"Студент объяснил код на интервью, всё ок\"\n}"
            }
          }
        },
        {
          "name": "Разрешить — CONFIRMED (плагиат подтверждён)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{instructor_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/instructor/queue/{{queue_item_id}}/resolve",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\",\n  \"instructor_note\": \"Студент не смог объяснить ни одну строку кода\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "09 · Edge Cases",
      "item": [
        {
          "name": "❌ 404 — несуществующий роут",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/nonexistent"
          }
        },
        {
          "name": "❌ 401 — фейковый токен",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer fake.token.here" }],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "❌ 404 — сабмишн не существует",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{student_token}}" }],
            "url": "{{base_url}}/submissions/nonexistent-id-123"
          }
        }
      ]
    }
  ]
}
