# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://syllab:syllab_pass@localhost:5433/syllab_db"

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT (min 32 chars each) ────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change_me_access_secret_min_32_characters"
JWT_REFRESH_SECRET="change_me_refresh_secret_min_32_characters"
JWT_ACCESS_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="30d"

# ── Encryption (exactly 32 chars) ─────────────────────────────────────────────
ENCRYPTION_KEY="change_me_32_chars_exactly_here!!"

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"
APP_URL="http://localhost:3000"

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# Gmail example: use an App Password (not your real password).
# Generate one at https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your_gmail@gmail.com"
SMTP_PASS="your_app_password_here"
FROM_EMAIL="your_gmail@gmail.com"

# ── Scoring thresholds ─────────────────────────────────────────────────────────
THRESHOLD_WATCH=0.27
THRESHOLD_REVIEW=0.50
THRESHOLD_ESCALATE=0.65
THRESHOLD_HIGH_RISK=0.80

# ── Gemini LLM (optional — for interview guidance generation) ──────────────────
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-flash-lite-preview"
